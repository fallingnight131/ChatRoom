# ChatRoom server environment variables
# Copy this file to .env and fill your own value.
# Place the .env file next to the server executable, or in the project root.

CHATROOM_DEVELOPER_KEY=change_me_to_a_strong_secret

# ========== 腾讯云 COS 对象存储（可选，留空则禁用） ==========
# 在腾讯云控制台 -> 访问管理 -> API密钥管理 中获取
COS_SECRET_ID=
COS_SECRET_KEY=

# 存储桶名称，格式: bucketname-appid  （例: chatroom-1250000000）
COS_BUCKET=

# 存储桶地域（例: ap-shanghai, ap-guangzhou）
COS_REGION=

# 内网 Endpoint（腾讯云轻量/CVM 服务器通过内网上传，免流量费）
# 格式: bucketname-appid.cos.internal.ap-region.myqcloud.com
COS_INTERNAL_ENDPOINT=

# 外网 Endpoint（客户端下载/预览使用）
# 格式: bucketname-appid.cos.ap-region.myqcloud.com
COS_EXTERNAL_ENDPOINT=

# COS 对象键前缀（可选，例: chatroom/ ）
COS_PREFIX=
